{
  "name": "arlo-lite",
  "version": "1.0.0",
  "description": "A lightweight LLM client - bring your own API key",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-navigation/drawer": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/stack": "^7.0.0",
    "expo": "~52.0.0",
    "expo-clipboard": "~7.0.1",
    "expo-localization": "~16.0.1",
    "expo-secure-store": "~14.0.0",
    "expo-sqlite": "~15.0.0",
    "expo-status-bar": "~2.0.0",
    "i18next": "^24.0.0",
    "react": "18.3.1",
    "react-i18next": "^15.0.0",
    "react-native": "0.76.7",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "~4.14.0",
    "react-native-screens": "~4.4.0",
    "react-syntax-highlighter": "^15.6.1",
    "uuid": "^11.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.0",
    "@types/react-native": "~0.73.0",
    "@types/react-syntax-highlighter": "^15.5.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.0.0",
    "fast-check": "^3.23.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "typescript": "~5.6.0"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|uuid)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "private": true
}
